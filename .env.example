# ─── CROO SDK Keys ─────────────────────────────────────────────────────────────
# Get from: https://agent.croo.network/dashboard
CROO_SDK_KEY_PROVIDER=croo_sk_provider_xxx
CROO_SDK_KEY_EXECUTOR=croo_sk_executor_xxx

# ─── CROO API Endpoints ─────────────────────────────────────────────────────────
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# ─── Candidate Agents ───────────────────────────────────────────────────────────
# Comma-separated CROO service IDs for candidate agents (separate SDK keys)
# Leave blank to use CANDIDATE_AGENTS_CONFIG file, or built-in dev candidates
CROO_TARGET_SERVICE_IDS=svc_research_alpha,svc_verify_beta,svc_format_gamma

# Optional: path to JSON config file for live candidate agents
# CANDIDATE_AGENTS_CONFIG=./config/candidate-agents.json

# ─── Operating Mode ─────────────────────────────────────────────────────────────
# DEMO_MODE=true   → simulation fallback allowed (logged as SimulationFallbackUsed)
# STRICT_CAP_MODE=true → real CAP only, no simulation. Use for final submission.
DEMO_MODE=true
STRICT_CAP_MODE=false

# ─── CAP Coordinator Settings ────────────────────────────────────────────────────
# Number of retries for failed sub-orders (default: 2)
CAP_SUBORDER_MAX_RETRIES=2

# ─── Base Chain ─────────────────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org

# ─── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=file:./data/trustrouter.db

# ─── API / Dashboard Ports ───────────────────────────────────────────────────────
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
