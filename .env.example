# CROO API Configuration
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# Agent API Keys (from CROO Dashboard)
CROO_SDK_KEY_PROVIDER=croo_sk_your_provider_key_here
CROO_SDK_KEY_EXECUTOR=croo_sk_your_executor_key_here

# Target candidate agent service IDs (comma-separated)
CROO_TARGET_SERVICE_IDS=svc_research_alpha,svc_verify_beta,svc_format_gamma

# Base Chain RPC
BASE_RPC_URL=https://mainnet.base.org

# Dashboard API
DASHBOARD_API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Database
DATABASE_URL=file:./data/trustrouter.db
